# Groq API
GROQ_API_KEY=gsk_...
GROQ_MODEL=qwen/qwen3-32b

# Qdrant (при запуске локально — http://localhost:6333)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=hf_corpus

# Redis (при запуске локально — redis://localhost:6379)
REDIS_URL=redis://redis:6379
CACHE_TTL=3600

# Модели
EMBEDDING_MODEL=intfloat/multilingual-e5-large
RERANKER_MODEL=BAAI/bge-reranker-large
TOP_K_RETRIEVE=20
TOP_K_FINAL=5

# Корпус
CORPUS_PATH=rag_corpus_cleaned_v2/corpus.jsonl
CHUNK_SIZE=400
CHUNK_OVERLAP=50
